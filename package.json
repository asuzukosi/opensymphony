{
  "name": "symphony-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.8",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "turbo clean",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "bun run --filter @symphony/desktop rebuild:native"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.10.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@dnd-kit/sortable": "^10.0.0",
    "react-router-dom": "^7.15.1"
  }
}
