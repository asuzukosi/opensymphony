{
  "name": "@symphony/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run rebuild:native && node scripts/dev-desktop.mjs",
    "dev:web": "vite",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 -m ../..",
    "rebuild:node": "npm rebuild better-sqlite3 --prefix ../..",
    "build": "tsc -p tsconfig.json --noEmit && node scripts/build-electron.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "merge-sort": "bun src/runtime/merge-sort.ts",
    "sorting-algorithms": "bun src/runtime/sorting-algorithms.ts",
    "clean": "rm -rf dist .electron"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.22.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@symphony/core": "workspace:*",
    "@symphony/db": "workspace:*",
    "@symphony/ui": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.15.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "happy-dom": "^20.0.10",
    "esbuild": "^0.28.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "electron": "^37.4.0",
    "vite": "^7.1.10"
  }
}
