{
  "name": "@symphony/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run rebuild:native && node scripts/dev-desktop.mjs",
    "dev:web": "vite",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3 -m .",
    "build": "tsc -p tsconfig.json --noEmit",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@symphony/core": "workspace:*",
    "@symphony/db": "workspace:*",
    "@symphony/ui": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "esbuild": "^0.28.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "electron": "^37.4.0",
    "vite": "^7.1.10"
  }
}
